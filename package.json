{
  "name": "medusa-rls-poc",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:rls-user": "medusa exec ./src/scripts/seed-rls-user.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:rls-patch": "NODE_OPTIONS=--experimental-vm-modules jest integration-tests/http/tenant-context/rls-patch.spec.ts --forceExit",
    "test:rls-customers": "NODE_OPTIONS=--experimental-vm-modules jest integration-tests/http/tenant-context/rls-customers-api.spec.ts --forceExit",
    "test:rls-products": "NODE_OPTIONS=--experimental-vm-modules jest integration-tests/http/tenant-context/rls-products-api.spec.ts --forceExit",
    "lint:tenant-scope": "node ./scripts/check-tenant-scope.js",
    "migration:backfill:capture": "node ./scripts/backfill-capture-baseline.js",
    "migration:backfill:validate": "node ./scripts/backfill-validate.js",
    "security:validate-controls": "node ./scripts/validate-security-controls.js",
    "analytics:validate-pipeline": "node ./scripts/validate-analytics-pipeline.js",
    "release:quality-gate": "node ./scripts/release-quality-gate.js",
    "release:orchestrate": "node ./scripts/release-orchestrator.js",
    "dora:metrics": "node ./scripts/dora-metrics.js",
    "compliance:readiness": "node ./scripts/compliance-readiness.js"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.6",
    "@medusajs/cli": "2.13.6",
    "@medusajs/framework": "2.13.6",
    "@medusajs/medusa": "2.13.6",
    "patch-package": "^8.0.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.6",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
